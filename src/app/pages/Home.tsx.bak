import { useState, useEffect } from 'react';
import { Link } from 'react-router';
import {
  Shield, Award, Clock, Users, CheckCircle, ArrowRight,
  Package, Microscope, HeartPulse, Star, TrendingUp, Globe, Phone,
  ChevronDown, ChevronUp, Quote, BadgeCheck, Truck, ThumbsUp,
  FlaskConical, Pill, Syringe, Droplets,
} from 'lucide-react';
import { productAPI, categoryAPI, contentAPI } from '../services/api';
import { Product, Category, SiteContent } from '../types';
import InquiryModal from '../components/InquiryModal';

const DEFAULT_CONTENT: SiteContent = {
  heroTitle: 'Your Trusted Pharma Wholesale Partner',
  heroSubtitle: 'Biolex Pharmaceutical Private Limited — supplying quality medicines to wholesalers and healthcare professionals across India.',
  heroBadge: 'ISO 9001:2015 Certified Pharmaceutical Company',
  featuresTitle: 'Why Biolex Pharmaceutical?',
  featuresSubtitle: 'Your reliable partner for quality pharmaceutical products',
  statsYears: '5+', statsProducts: '500+', statsPartners: '100+', statsSupport: '24/7',
  testimonialTitle: 'What Our Partners Say',
  testimonialSubtitle: 'Trusted by healthcare professionals and distributors across India',
  faqTitle: 'Frequently Asked Questions',
  faqSubtitle: 'Get answers to common questions about our pharmaceutical wholesale services',
  ctaTitle: 'Ready to Partner With Us?',
  ctaSubtitle: 'Send us an inquiry for product details, pricing, and availability. Our team responds within 24 hours.',
  whyUsTitle: 'Why Choose Biolex?',
  whyUsSubtitle: 'We go beyond just supplying medicines — we build lasting partnerships',
};

export default function Home() {
  const [products, setProducts] = useState<Product[]>([]);
  const [categories, setCategories] = useState<Category[]>([]);
  const [loading, setLoading] = useState(true);
  const [content, setContent] = useState<SiteContent>(DEFAULT_CONTENT);
  const [inquiryOpen, setInquiryOpen] = useState(false);
  const [selectedProduct, setSelectedProduct] = useState<Product | null>(null);
  const [openFaq, setOpenFaq] = useState<number | null>(null);

  useEffect(() => {
    const fetchData = async () => {
      try {
        const [pRes, cRes, ctRes]: any[] = await Promise.all([
          productAPI.getAll(),
          categoryAPI.getAll(),
          contentAPI.getSection('home'),
        ]);
        if (pRes.success) setProducts((pRes.data || []).slice(0, 6));
        if (cRes.success) setCategories(cRes.data || []);
        if (ctRes.success) setContent({ ...DEFAULT_CONTENT, ...ctRes.data });
      } catch (_) {}
      finally { setLoading(false); }
    };
    fetchData();
  }, []);

  const openInquiry = (product: Product) => { setSelectedProduct(product); setInquiryOpen(true); };

  const features = [
    { icon: Shield, title: 'ISO 9001:2015 Certified', desc: 'Quality assured pharmaceutical products meeting international standards', color: 'text-blue-600', bg: 'bg-blue-50' },
    { icon: Package, title: 'Wide Product Range', desc: 'Comprehensive selection across all therapeutic categories', color: 'text-emerald-600', bg: 'bg-emerald-50' },
    { icon: Clock, title: 'On-Time Delivery', desc: 'Reliable and timely delivery to ensure continuous supply', color: 'text-orange-600', bg: 'bg-orange-50' },
    { icon: Users, title: 'B2B Focused', desc: 'Specialized service for wholesalers, distributors and professionals', color: 'text-purple-600', bg: 'bg-purple-50' },
  ];

  const stats = [
    { value: content.statsYears, label: 'Years Experience', icon: TrendingUp },
    { value: content.statsProducts, label: 'Products', icon: Package },
    { value: content.statsPartners, label: 'Partners', icon: Users },
    { value: content.statsSupport, label: 'Support', icon: Globe },
  ];

  const whyUs = [
    { icon: BadgeCheck, title: 'ISO 9001:2015 Certified', desc: 'Full certification ensuring every product meets international quality benchmarks.' },
    { icon: Truck, title: 'On-Time Delivery', desc: 'Reliable logistics ensuring your supplies reach you exactly when needed.' },
    { icon: ThumbsUp, title: 'Competitive Pricing', desc: 'Best wholesale prices with no compromise on product quality or authenticity.' },
    { icon: Shield, title: 'Quality Assurance', desc: 'Every medicine verified and sourced from trusted manufacturers across India.' },
    { icon: Users, title: 'Dedicated Support', desc: 'Our team is always available to help with inquiries and after-sales support.' },
    { icon: Globe, title: 'Pan-India Network', desc: 'Established distribution network covering all major states and cities in India.' },
  ];

  const testimonials = [
    { name: 'Rajesh Sharma', role: 'Medical Store Owner, Delhi', rating: 5, text: 'Biolex has been our trusted supplier for over 2 years. Excellent quality products and always on-time delivery. Highly recommended for any pharma business.' },
    { name: 'Priya Patel', role: 'Distributor, Mumbai', rating: 5, text: 'The product range is extensive and prices are very competitive. The team is professional and responds quickly to all our inquiries.' },
    { name: 'Dr. Amit Singh', role: 'Clinic Owner, Chandigarh', rating: 4, text: 'Great quality medicines sourced from certified manufacturers. Our clinic has been sourcing from Biolex and the consistency has been impressive.' },
  ];

  const faqs = [
    { q: 'What is the minimum order quantity?', a: 'We cater to B2B orders. Minimum quantities vary by product. Please contact us for specific product MOQs and bulk pricing.' },
    { q: 'Do you offer PAN India delivery?', a: 'Yes, we deliver across all major cities and states in India. Delivery timelines depend on your location and order size.' },
    { q: 'Are your products certified?', a: 'All our products are sourced from ISO-certified manufacturers and meet regulatory standards set by DCGI and other authorities.' },
    { q: 'How can I get the latest price list?', a: 'Please send an inquiry through our Contact page or call us directly. Our team will share the latest price list within 24 hours.' },
    { q: 'Do you offer credit terms for distributors?', a: 'We offer flexible payment terms for established distributors. Contact our sales team to discuss credit arrangements.' },
    { q: 'What product categories do you carry?', a: 'We carry Tablets, Capsules, Syrups, Injections, Drops, Protein Powders, Energy Drinks, and PCD Pharma Franchise products.' },
  ];

  const certifications = [
    { title: 'ISO 9001:2015', desc: 'Quality Management', icon: BadgeCheck, color: 'blue' },
    { title: 'DCGI Compliant', desc: 'Drug Controller Approved', icon: Shield, color: 'green' },
    { title: 'GMP Certified', desc: 'Good Manufacturing Practices', icon: Award, color: 'purple' },
    { title: 'GST Registered', desc: 'No. 04AAJCB2451N1ZM', icon: CheckCircle, color: 'orange' },
  ];

  const productTypes = [
    { icon: Pill, label: 'Tablets', color: 'bg-blue-50 text-blue-600' },
    { icon: Package, label: 'Capsules', color: 'bg-purple-50 text-purple-600' },
    { icon: FlaskConical, label: 'Syrups', color: 'bg-emerald-50 text-emerald-600' },
    { icon: Syringe, label: 'Injections', color: 'bg-red-50 text-red-600' },
    { icon: Droplets, label: 'Drops', color: 'bg-cyan-50 text-cyan-600' },
    { icon: Globe, label: 'PCD Franchise', color: 'bg-orange-50 text-orange-600' },
