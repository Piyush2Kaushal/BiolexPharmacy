                    <span className="text-sm">{item}</span>
                  </div>
                ))}
              </div>
              <Link to="/about" className="inline-flex items-center gap-2 bg-white text-blue-700 px-7 py-3.5 rounded-xl font-semibold hover:bg-blue-50 transition-colors">
                Learn More <ArrowRight className="w-5 h-5" />
              </Link>
            </div>
            <div className="bg-white/10 backdrop-blur-sm rounded-2xl border border-white/20 p-8 space-y-5">
              {[
                { label: 'CEO', value: 'Ravi Kumar Bhalla' },
                { label: 'Location', value: 'Manimajra, Chandigarh' },
                { label: 'Business Type', value: 'Wholesaler / Distributor' },
                { label: 'Established', value: '2021' },
                { label: 'Certification', value: 'ISO 9001:2015' },
                { label: 'GST No.', value: '04AAJCB2451N1ZM' },
              ].map((item, i) => (
                <div key={i} className="flex justify-between items-center border-b border-white/10 pb-4 last:border-0 last:pb-0">
